{
  "description": "an apex listed in vhost exclude_zones is NOT redirected to nginx; it serves its flattened cfargotunnel addresses",
  "config": {
    "local_zones": [
      "excluded.test"
    ],
    "vhost_v4": "192.0.2.10",
    "vhost_v6": "2001:db8::10",
    "exclude_zones": [
      "excluded.test"
    ]
  },
  "zones": [
    {
      "name": "excluded.test",
      "id": "z1",
      "records": [
        {
          "type": "CNAME",
          "name": "excluded.test",
          "content": "abc123.cfargotunnel.com",
          "proxied": true,
          "ttl": 300
        }
      ]
    }
  ],
  "tunnel_addrs": {
    "excluded.test.": {
      "v4": [
        "203.0.113.50"
      ],
      "v6": [
        "2001:db8::50"
      ]
    }
  },
  "queries": [
    {
      "name": "excluded.test",
      "type": "A",
      "rcode": "NOERROR",
      "aa": true,
      "answer": [
        "excluded.test.\t300\tIN\tA\t203.0.113.50"
      ]
    },
    {
      "name": "excluded.test",
      "type": "AAAA",
      "rcode": "NOERROR",
      "aa": true,
      "answer": [
        "excluded.test.\t300\tIN\tAAAA\t2001:db8::50"
      ]
    }
  ]
}
