#!/bin/sh
# splitdnsd-autobuild — keep splitdnsd/splitdns-notify installed and built against the
# CURRENT apt Go toolchain. When the toolchain changes (e.g. an Ubuntu stdlib security
# backport) it rebuilds; when either package has been removed it reinstalls it. Either of
# the two binary packages may be absent — this helper SELF-HEALS the suite (it does not
# hard-depend on them, so any combination of the three packages is a valid install). New
# builds install only after config-validation + a DNS health check, with AUTOMATIC
# ROLLBACK. This is what lets a statically linked resolver pick up Go stdlib fixes on
# `apt dist-upgrade` the way a dynamically linked program picks up a patched shared
# library (design §11).
#
# Run by the apt hook (after every apt run) and weekly by the timer. It is a fast no-op
# unless something actually needs (re)building. On ANY failure it exits non-zero so the
# systemd OnFailure= notifier emails the administrator (the work happens off the apt
# transaction, so failures are no longer seen synchronously).
#
# It must run as root (dpkg/apt + systemctl). DNS is never taken down: a bad build is
# caught before/after install and rolled back to the previously-installed packages.
set -eu

LIBDIR=/usr/lib/splitdnsd-selfbuild
CONF=/etc/splitdns/autobuild.conf
[ -r "$CONF" ] && . "$CONF"
: "${ENABLE:=yes}"
: "${SRC_TARBALL:=/usr/src/splitdnsd/source.tar.gz}"
: "${BUILD_DIR:=/var/cache/splitdnsd-selfbuild}"
: "${HEALTH_NAME:=health.splitdnsd.local}"
: "${HEALTH_ADDR:=127.0.0.1}"
: "${GOMAXPROCS:=2}"
export GOMAXPROCS

log() { logger -t splitdnsd-autobuild -- "$*" 2>/dev/null || true; echo "splitdnsd-autobuild: $*"; }
die() { log "ERROR: $*"; exit 1; }   # non-zero exit => systemd OnFailure= emails the admin

# --force rebuilds even when nothing changed (reinstalling the current version), for testing.
FORCE=no
for _a in "$@"; do [ "$_a" = --force ] && FORCE=yes; done

[ "$ENABLE" = yes ] || { log "disabled in $CONF (ENABLE=$ENABLE); skipping"; exit 0; }
[ -d /run/systemd/system ] || { log "not under systemd; skipping"; exit 0; }
[ "$(id -u)" = 0 ] || die "must run as root"

# Keep the cache dir from growing: wipe the transient build workspace on exit, retaining
# only the latest rollback snapshot (rollback/, a few MB) and the logs. The Go build cache
# in particular is pointless to keep — every rebuild is triggered by a TOOLCHAIN change,
# which invalidates it, so each build is cold anyway.
cleanup() { rm -rf "$BUILD_DIR/src" "$BUILD_DIR/dist" "$BUILD_DIR/gocache" "$BUILD_DIR/gopath"; }
trap cleanup EXIT

ARCH=$(dpkg --print-architecture)

# Current state — either binary package may be absent (the selfbuild self-heals a removal).
sd_ver=$(dpkg-query -W -f='${Version}' splitdnsd 2>/dev/null || true)
sn_ver=$(dpkg-query -W -f='${Version}' splitdns-notify 2>/dev/null || true)

# --- 1. Cheap change-detection: what version WOULD a fresh build stamp? ---------------
# pkg-version.sh derives it from the current apt golang package version — no compile.
base=$(cat "$LIBDIR/VERSION" 2>/dev/null || true)
[ -n "$base" ] || base="${sd_ver%%+*}"
[ -n "$base" ] || base="${sn_ver%%+*}"
[ -n "$base" ] || die "cannot determine base version (no $LIBDIR/VERSION and neither package installed)"
want=$(BASE_VERSION="$base" GO="$("$LIBDIR/select-go.sh" | head -1)" "$LIBDIR/pkg-version.sh" version) \
  || die "could not compute target version (no apt Go toolchain?)"

# A package needs (re)building if it is missing, older than the target, or --force is given.
need_pkg() {  # $1 = installed version ("" if absent)
  [ "$FORCE" = yes ] && return 0
  [ -z "$1" ] && return 0
  dpkg --compare-versions "$1" lt "$want"
}
need_sd=no; need_pkg "$sd_ver" && need_sd=yes
need_sn=no; need_pkg "$sn_ver" && need_sn=yes

if [ "$need_sd" = no ] && [ "$need_sn" = no ]; then
  log "up to date (splitdnsd=${sd_ver:-absent} splitdns-notify=${sn_ver:-absent}, target $want); nothing to do"
  exit 0
fi
log "(re)building (splitdnsd=$need_sd splitdns-notify=$need_sn) installed sd=${sd_ver:-absent} sn=${sn_ver:-absent} -> target $want"

# --- 2. Rebuild from the shipped source (hermetic, vendored, capped parallelism) ------
[ -r "$SRC_TARBALL" ] || die "source tarball $SRC_TARBALL missing"
rm -rf "$BUILD_DIR/src" "$BUILD_DIR/dist"
mkdir -p "$BUILD_DIR/src" "$BUILD_DIR/gocache" "$BUILD_DIR/gopath"
# A systemd service has NO $HOME, so `go build` cannot otherwise locate its build cache
# ("build cache is required, but could not be located"). Pin the Go caches (and HOME)
# under our writable cache dir so the build behaves identically from systemd and a shell.
export GOCACHE="$BUILD_DIR/gocache" GOPATH="$BUILD_DIR/gopath" HOME="$BUILD_DIR"
tar -C "$BUILD_DIR/src" -xzf "$SRC_TARBALL" || die "could not unpack $SRC_TARBALL"
( cd "$BUILD_DIR/src" && BASE_VERSION="$base" OUT="$BUILD_DIR/dist" ./scripts/build-deb.sh ) \
  >"$BUILD_DIR/build.log" 2>&1 || { tail -40 "$BUILD_DIR/build.log" | sed 's/^/  build: /'; die "build failed (see $BUILD_DIR/build.log)"; }

srv="$BUILD_DIR/dist/splitdnsd_${want}_${ARCH}.deb"
hlp="$BUILD_DIR/dist/splitdns-notify_${want}_${ARCH}.deb"
[ "$need_sd" = no ] || [ -r "$srv" ] || die "expected splitdnsd deb not produced ($srv)"
[ "$need_sn" = no ] || [ -r "$hlp" ] || die "expected splitdns-notify deb not produced ($hlp)"

# --- 3. Validate the new splitdnsd binary against the LIVE config BEFORE committing ----
if [ "$need_sd" = yes ] && [ -e /etc/splitdns/splitdnsd.toml ]; then
  vtmp=$(mktemp -d)
  dpkg-deb -x "$srv" "$vtmp" || die "could not unpack new deb for validation"
  "$vtmp/usr/sbin/splitdnsd" -config /etc/splitdns/splitdnsd.toml -check-config \
    || { rm -rf "$vtmp"; die "new binary fails -check-config against the live config; not installing"; }
  rm -rf "$vtmp"
fi

# --- 4. Snapshot the currently-installed packages for rollback ------------------------
# The rollback snapshot is the safety net for unattended UPGRADES, so it is mandatory for
# any package that is currently installed (dpkg-repack a not-installed package would fail).
# A freshly-installed (previously-absent) package has no prior state — its "rollback" is to
# remove it again, handled in rollback() below.
mkdir -p "$BUILD_DIR/rollback"
rm -f "$BUILD_DIR/rollback"/*.deb
repack=""
[ -n "$sd_ver" ] && repack="$repack splitdnsd"
[ -n "$sn_ver" ] && repack="$repack splitdns-notify"
if [ -n "$repack" ]; then
  command -v dpkg-repack >/dev/null 2>&1 \
    || die "dpkg-repack not installed; cannot snapshot a rollback target — refusing to install (apt install dpkg-repack)"
  # shellcheck disable=SC2086
  ( cd "$BUILD_DIR/rollback" && dpkg-repack $repack ) \
    || die "dpkg-repack could not snapshot the current packages — refusing to install without a rollback target"
  ls "$BUILD_DIR"/rollback/*.deb >/dev/null 2>&1 \
    || die "rollback snapshot produced no .deb — refusing to install without a rollback target"
fi

# --- 5. Install the needed packages, health-gate, roll back on any failure ------------
rollback() {
  if ls "$BUILD_DIR"/rollback/*.deb >/dev/null 2>&1; then
    log "rolling back to the previously-installed packages"
    apt-get install -y --allow-downgrades --reinstall "$BUILD_DIR"/rollback/*.deb >/dev/null 2>&1 \
      || log "WARN: rollback install reported errors"
  fi
  # A package we freshly installed this run had no prior state — remove it to return there.
  [ "$need_sd" = yes ] && [ -z "$sd_ver" ] && { log "removing freshly-installed splitdnsd"; apt-get remove -y splitdnsd >/dev/null 2>&1 || true; }
  [ "$need_sn" = yes ] && [ -z "$sn_ver" ] && { apt-get remove -y splitdns-notify >/dev/null 2>&1 || true; }
}

health_ok() {
  # Unconfigured resolver: the unit is inactive BY DESIGN (ConditionPathExists), so a
  # binary swap is harmless and there is nothing to probe.
  [ -e /etc/splitdns/splitdnsd.toml ] || return 0
  systemctl is-active --quiet splitdnsd || return 1
  # Confirm it actually answers DNS. dig exits 0 on any response (even NXDOMAIN), non-zero
  # only when the server does not reply. If dig is unavailable, the is-active check stands.
  command -v dig >/dev/null 2>&1 || return 0
  dig +tries=1 +time=2 "@$HEALTH_ADDR" "$HEALTH_NAME" >/dev/null 2>&1
}

install_list=""
[ "$need_sd" = yes ] && install_list="$install_list $srv"
[ "$need_sn" = yes ] && install_list="$install_list $hlp"
# --reinstall is needed when the target is not strictly newer than an installed package
# (e.g. --force reinstalling the same version).
reinstall=""
{ [ "$need_sd" = yes ] && [ -n "$sd_ver" ] && dpkg --compare-versions "$want" le "$sd_ver"; } && reinstall="--reinstall"
{ [ "$need_sn" = yes ] && [ -n "$sn_ver" ] && dpkg --compare-versions "$want" le "$sn_ver"; } && reinstall="--reinstall"

# shellcheck disable=SC2086
if ! apt-get install -y --allow-downgrades $reinstall $install_list >"$BUILD_DIR/install.log" 2>&1; then
  tail -20 "$BUILD_DIR/install.log" | sed 's/^/  install: /'
  rollback
  die "install of $want failed; rolled back"
fi

# Health-gate only matters when splitdnsd was (re)installed — splitdns-notify is a CLI
# helper with no daemon to probe.
if [ "$need_sd" = yes ]; then
  i=0
  while [ $i -lt 10 ]; do health_ok && break; i=$((i+1)); sleep 1; done
  if ! health_ok; then
    rollback
    die "new splitdnsd $want did not pass the health check; rolled back"
  fi
fi

log "self-build OK -> $want (splitdnsd=$need_sd splitdns-notify=$need_sn, healthy)"
exit 0
